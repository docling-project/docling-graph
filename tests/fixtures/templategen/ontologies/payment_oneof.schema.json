{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Payment",
  "description": "A payment record.",
  "type": "object",
  "required": ["payment_id"],
  "properties": {
    "payment_id": {"type": "string", "examples": ["PAY-77", "PAY-78"]},
    "method": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {"type": "string"},
            "card_last4": {"type": "string"}
          }
        },
        {
          "type": "object",
          "properties": {
            "kind": {"type": "string"},
            "iban": {"type": "string"}
          }
        }
      ]
    }
  }
}
